{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/social/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
