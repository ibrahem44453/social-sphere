# ============================================================
# Required environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# PostgreSQL database connection string (required at runtime)
DATABASE_URL=postgresql://user:password@localhost:5432/social

# OpenAI integration — provisioned via Replit AI Integrations
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Supabase credentials for frontend auth
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Port the API server listens on (runtime only, not needed for build)
PORT=3000

# Base URL path for the frontend Vite app (e.g. "/" for root deployment)
BASE_PATH=/
